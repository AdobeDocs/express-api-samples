# Copy to .env and fill in real values from your Adobe Developer Console
# project (OAuth Server-to-Server credential for the Adobe Express API).

CLIENT_ID=your_s2s_client_id_here
CLIENT_SECRET=your_s2s_client_secret_here

# Comma-separated scopes for the Server-to-Server credential. Override if your
# org's credential requires additional scopes (e.g. read_organizations).
SCOPES=openid,AdobeID,ee.express_api,read_organizations

# URN of the Express project where generated variations should land, e.g.
# urn:aaid:sc:EU:abc123... . The technical account must be a member of the
# project (Can edit), and so must the end users who will edit the variations.
# See "Admin Console setup" in the README.
SHARED_PROJECT_ID=

# Adobe Express Embed SDK client ID. Used in the browser to initialize
# CCEverywhere so the user can open the generated variation in an embedded
# editor. This is a DIFFERENT credential from the S2S one above — create an
# OAuth Web App (or Single-page App) credential in the SAME Developer Console
# project and paste its client_id here. The VITE_ prefix is required for Vite
# to expose the variable to client-side code.
VITE_EMBED_SDK_CLIENT_ID=your_embed_sdk_client_id_here

# Set to "development" to enable GET /debug/token. Anything else disables it.
NODE_ENV=development