# Copy to .env and fill in real values from your Adobe Developer Console
# project (OAuth Web App credential for the Adobe Express API).

CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Must exactly match a redirect URI registered on the credential.
REDIRECT_URI=https://localhost:4000/callback

# Any random string. Used to sign the session cookie.
SESSION_SECRET=change_me_to_a_long_random_string

# Optional. Defaults to 4000.
PORT=4000

# Set to "development" to enable GET /debug/token. Anything else disables it.
NODE_ENV=development

# Adobe Express Embed SDK client ID. Used in the browser to initialize
# CCEverywhere so the user can open the generated variation in an embedded
# editor (see "Open in the Embed SDK" button). The VITE_ prefix is required
# for Vite to expose the variable to client-side code.
VITE_EMBED_SDK_CLIENT_ID=your_embed_sdk_client_id_here
